{
  "name": "connor-dashboard",
  "version": "1.0.0",
  "description": "Connor's personal command center",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win --x64",
    "build": "electron-builder --mac --win"
  },
  "author": "Connor Calfee",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.connorcalfee.dashboard",
    "productName": "Connor Dashboard",
    "copyright": "Connor Calfee",
    "directories": { "output": "dist" },
    "files": [
      "main.js",
      "server.js",
      "src/**/*",
      "assets/**/*"
    ],
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "extendInfo": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "dmg": {
      "title": "Connor Dashboard",
      "contents": [
        { "x": 410, "y": 150, "type": "link", "path": "/Applications" },
        { "x": 130, "y": 150, "type": "file" }
      ],
      "window": { "width": 540, "height": 300 }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Connor Dashboard"
    }
  }
}
